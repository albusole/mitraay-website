---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title,
  description,
  ogImage = '/images/hero-yoga-sunrise-pavilion.jpg',
  ogTitle,
  ogDescription,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `https://mitraayresort.in${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/logo-transparent.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={ogDescription || description} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=Caveat:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <!-- Navigation -->
    <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-4 px-6 lg:px-12">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group" aria-label="Mitraay Resort Home">
          <img src="/images/logo-transparent.png" alt="Mitraay logo mark" class="h-10 w-10 object-contain" />
          <span id="nav-logo-text" class="font-['Playfair_Display'] text-xl font-semibold text-white transition-colors duration-300">Mitraay Agro Resort</span>
        </a>

        <!-- Desktop links -->
        <div class="hidden lg:flex items-center gap-8">
          <a href="/adventure" id="nav-link-1" class="nav-link text-white/90 hover:text-[#F5B04A] transition-colors duration-200 font-medium text-sm tracking-wide">Adventure</a>
          <a href="/retreat" id="nav-link-2" class="nav-link text-white/90 hover:text-[#F5B04A] transition-colors duration-200 font-medium text-sm tracking-wide">Retreat</a>
          <a href="/school" id="nav-link-3" class="nav-link text-white/90 hover:text-[#F5B04A] transition-colors duration-200 font-medium text-sm tracking-wide">School Trips</a>
          <a href="/property" id="nav-link-4" class="nav-link text-white/90 hover:text-[#F5B04A] transition-colors duration-200 font-medium text-sm tracking-wide">Property</a>
          <a href="/contact" id="nav-link-5" class="nav-link text-white/90 hover:text-[#F5B04A] transition-colors duration-200 font-medium text-sm tracking-wide">Contact</a>
          <a
            href="https://wa.me/919112984575?text=Hi%2C%20I%20want%20to%20plan%20a%20group%20trip%20to%20Mitraay%20Resort"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-[#E8871A] hover:bg-[#C96D0A] text-white px-5 py-2.5 rounded-full text-sm font-semibold transition-all duration-200 shadow-lg hover:shadow-xl"
          >
            Plan Your Trip
          </a>
        </div>

        <!-- Mobile hamburger -->
        <button id="hamburger" class="lg:hidden flex flex-col gap-1.5 p-2" aria-label="Open menu">
          <span class="ham-line block w-6 h-0.5 bg-white transition-all duration-300"></span>
          <span class="ham-line block w-6 h-0.5 bg-white transition-all duration-300"></span>
          <span class="ham-line block w-6 h-0.5 bg-white transition-all duration-300"></span>
        </button>
      </div>
    </nav>

    <!-- Mobile full-screen overlay -->
    <div id="mobile-menu" class="fixed inset-0 z-40 bg-[#2C1F0E] flex flex-col items-center justify-center opacity-0 pointer-events-none transition-all duration-400">
      <div class="flex flex-col items-center gap-8 text-center">
        <a href="/" class="text-white/70 font-['Playfair_Display'] text-3xl hover:text-[#F5B04A] transition-colors">Home</a>
        <a href="/adventure" class="text-white/70 font-['Playfair_Display'] text-3xl hover:text-[#F5B04A] transition-colors">Adventure</a>
        <a href="/retreat" class="text-white/70 font-['Playfair_Display'] text-3xl hover:text-[#F5B04A] transition-colors">Retreat</a>
        <a href="/school" class="text-white/70 font-['Playfair_Display'] text-3xl hover:text-[#F5B04A] transition-colors">School Trips</a>
        <a href="/property" class="text-white/70 font-['Playfair_Display'] text-3xl hover:text-[#F5B04A] transition-colors">Property</a>
        <a href="/contact" class="text-white/70 font-['Playfair_Display'] text-3xl hover:text-[#F5B04A] transition-colors">Contact</a>
        <a
          href="https://wa.me/919112984575?text=Hi%2C%20I%20want%20to%20plan%20a%20group%20trip%20to%20Mitraay%20Resort"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 bg-[#E8871A] text-white px-8 py-3 rounded-full text-lg font-semibold"
        >
          Plan Your Trip
        </a>
      </div>
    </div>

    <!-- Page content -->
    <slot />

    <!-- WhatsApp floating button -->
    <a
      href="https://wa.me/919112984575?text=Hi%2C%20I%20want%20to%20plan%20a%20group%20trip%20to%20Mitraay%20Resort"
      target="_blank"
      rel="noopener noreferrer"
      class="wa-float fixed bottom-6 right-6 z-50 bg-[#25D366] text-white w-14 h-14 rounded-full flex items-center justify-center shadow-xl hover:bg-[#1da851] transition-colors duration-200"
      aria-label="Chat on WhatsApp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <!-- Footer -->
    <footer class="bg-[#2C1F0E] text-white py-16 px-6 lg:px-12">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
          <!-- Brand column -->
          <div class="lg:col-span-2">
            <div class="flex items-center gap-3 mb-4">
              <img src="/images/logo-transparent.png" alt="Mitraay logo" class="h-12 w-12 object-contain" />
              <span class="font-['Playfair_Display'] text-3xl font-semibold">Mitraay</span>
            </div>
            <p class="text-white/60 text-sm leading-relaxed max-w-sm">A purposeful farm retreat near Raigad Fort, Raigad, Maharashtra. Built for groups who want more than a getaway.</p>
            <p class="text-white/40 text-xs mt-4 tracking-[0.1em] uppercase">A project by Vedbhoomi Eco Village</p>
            <a href="https://www.instagram.com/mitraayresort/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-4 text-white/50 hover:text-[#F5B04A] transition-colors text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
              </svg>
              @mitraayresort
            </a>
          </div>

          <!-- Links -->
          <div>
            <h4 class="font-['Playfair_Display'] text-lg mb-5 text-[#F5B04A]">Explore</h4>
            <ul class="space-y-3 text-sm text-white/70">
              <li><a href="/adventure" class="hover:text-[#F5B04A] transition-colors">Adventure</a></li>
              <li><a href="/retreat" class="hover:text-[#F5B04A] transition-colors">Retreat</a></li>
              <li><a href="/school" class="hover:text-[#F5B04A] transition-colors">School Trips</a></li>
              <li><a href="/property" class="hover:text-[#F5B04A] transition-colors">Property</a></li>
              <li><a href="/contact" class="hover:text-[#F5B04A] transition-colors">Contact</a></li>
            </ul>
            <p class="mt-5 text-xs text-white/50">Stayed with us? <a href="https://g.page/r/CVSPpp_e6fkzEBM/review" target="_blank" rel="noopener noreferrer" class="text-[#E8871A] hover:text-[#F5B04A] transition-colors">We'd love your review on Google</a></p>
          </div>

          <!-- Nearby & contact -->
          <div>
            <h4 class="font-['Playfair_Display'] text-lg mb-5 text-[#F5B04A]">Nearby</h4>
            <ul class="space-y-2 text-sm text-white/70 mb-6">
              <li>Raigad Fort · 25km</li>
              <li>Kumbhe Waterfall · 11km</li>
              <li>Ulhas River</li>
              <li>Mangaon · ~10km</li>
            </ul>
            <div class="space-y-2 text-sm">
              <a href="https://wa.me/919112984575" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-[#25D366] hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 shrink-0">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                +91 91129 84757
              </a>
              <a href="https://mitraayresort.in" class="text-white/50 hover:text-white transition-colors">mitraayresort.in</a>
            </div>
          </div>
        </div>

        <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
          <p class="text-white/40 text-sm">© 2026 Mitraay Resort · Raigad, Maharashtra</p>
        </div>
      </div>
    </footer>

    <!-- Lenis + GSAP init -->
    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // Smooth scroll
      const lenis = new Lenis({ lerp: 0.08 });

      lenis.on('scroll', ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });
      gsap.ticker.lagSmoothing(0);

      // Nav scroll state
      const nav = document.getElementById('main-nav');
      const logoText = document.getElementById('nav-logo-text');
      const navLinks = document.querySelectorAll('.nav-link');

      function updateNav() {
        if (!nav) return;
        if (window.scrollY > 80) {
          nav.style.background = 'rgba(0,0,0,0.4)';
          nav.style.backdropFilter = 'blur(12px)';
          nav.style.boxShadow = '0 1px 20px rgba(0,0,0,0.15)';
          nav.classList.remove('py-4');
          nav.classList.add('py-2');
        } else {
          nav.style.background = 'transparent';
          nav.style.backdropFilter = '';
          nav.style.boxShadow = '';
          nav.classList.remove('py-2');
          nav.classList.add('py-4');
        }
        if (logoText) logoText.style.color = 'white';
        navLinks.forEach(l => (l as HTMLElement).style.color = 'rgba(255,255,255,0.9)');
      }

      window.addEventListener('scroll', updateNav, { passive: true });
      updateNav();

      // Mobile menu
      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamLines = document.querySelectorAll('.ham-line');
      let menuOpen = false;

      hamburger?.addEventListener('click', () => {
        menuOpen = !menuOpen;
        if (menuOpen) {
          mobileMenu?.classList.remove('opacity-0', 'pointer-events-none');
          mobileMenu?.classList.add('opacity-100');
          hamLines[0]?.classList.add('rotate-45', 'translate-y-2');
          hamLines[1]?.classList.add('opacity-0');
          hamLines[2]?.classList.add('-rotate-45', '-translate-y-2');
        } else {
          mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
          mobileMenu?.classList.remove('opacity-100');
          hamLines[0]?.classList.remove('rotate-45', 'translate-y-2');
          hamLines[1]?.classList.remove('opacity-0');
          hamLines[2]?.classList.remove('-rotate-45', '-translate-y-2');
        }
      });

      // Close mobile menu on link click
      mobileMenu?.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          menuOpen = false;
          mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
          mobileMenu?.classList.remove('opacity-100');
          hamLines[0]?.classList.remove('rotate-45', 'translate-y-2');
          hamLines[1]?.classList.remove('opacity-0');
          hamLines[2]?.classList.remove('-rotate-45', '-translate-y-2');
        });
      });
    </script>
  </body>
</html>
