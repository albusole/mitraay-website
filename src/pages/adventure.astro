---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---

<Layout
  title="Adventure near Raigad Fort | Mitraay Resort"
  description="River swimming, Kolad rafting, Mangad Trek, Devkund & Kumbhe waterfalls, Raigad Fort. Custom adventure plan for your group."
  ogImage="/images/adventure-river-swimming-group.jpg"
>

  <!-- HERO -->
  <section class="relative h-[70vh] min-h-[500px] flex items-end overflow-hidden">
    <canvas id="adv-canvas" class="absolute inset-0 w-full h-full" style="display:block;"></canvas>
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
    <div class="relative z-10 pb-20 px-6 lg:px-12 max-w-7xl mx-auto w-full">
      <span class="font-['Caveat'] text-[#F5B04A] text-xl">Outdoors</span>
      <h1 id="adv-h1" class="font-['Playfair_Display'] text-5xl md:text-7xl font-bold text-white mt-2 leading-tight">
        Adventure
      </h1>
      <p id="adv-sub" class="text-white/80 text-xl mt-4 max-w-xl">
        Every trail, river, and bonfire is planned for your group.
      </p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="py-20 px-6 lg:px-12 bg-[#F7F0E6]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-['Playfair_Display'] text-4xl font-bold text-[#2C1F0E] mb-6" id="adv-intro-h">
        Built for groups who want to actually do things.
      </h2>
      <p class="text-[#4A3728] text-lg leading-relaxed">
        Mitraay sits in the Sahyadri foothills, on the river, 25km from Raigad Fort, and within day-trip distance of some of Maharashtra's best outdoor destinations. Every group gets a custom activity plan.
      </p>
    </div>
  </section>

  <!-- ON-PROPERTY ACTIVITIES -->
  <section class="py-16 px-6 lg:px-12 bg-[#EDE3D4]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <span class="font-['Caveat'] text-[#E8871A] text-2xl">Right here</span>
        <h2 class="font-['Playfair_Display'] text-3xl font-bold text-[#2C1F0E] mt-2">On-property experiences</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <div class="card bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200 adv-card">
          <div class="overflow-hidden h-[220px]">
            <img src="/images/adventure-trek-rocky-ridge-group.jpg" alt="Group on a nature walk through the farm at Mitraay Resort" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="p-6">
            <div class="w-10 h-10 rounded-xl bg-[#3A5C3A]/10 flex items-center justify-center mb-4 text-[#3A5C3A]">
              <Icon name="compass" class="w-5 h-5" />
            </div>
            <span class="text-xs font-semibold text-[#E8871A] uppercase tracking-wider">On-property</span>
            <h3 class="font-['Playfair_Display'] text-xl font-bold text-[#2C1F0E] mt-1 mb-2">Nature Walk</h3>
            <p class="text-[#4A3728] text-sm leading-relaxed">A guided walk through the working farm and Sahyadri foothills. Identify plants, birds, insects, and learn about the river ecosystem, no distance required.</p>
          </div>
        </div>

        <div class="card bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200 adv-card">
          <div class="overflow-hidden h-[220px]">
            <img src="/images/adventure-river-swimming-group.jpg" alt="Group swimming in the river at Mitraay Resort" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="p-6">
            <div class="w-10 h-10 rounded-xl bg-[#8B7355]/10 flex items-center justify-center mb-4 text-[#8B7355]">
              <Icon name="waves" class="w-5 h-5" />
            </div>
            <span class="text-xs font-semibold text-[#E8871A] uppercase tracking-wider">On-property</span>
            <h3 class="font-['Playfair_Display'] text-xl font-bold text-[#2C1F0E] mt-1 mb-2">River Swimming</h3>
            <p class="text-[#4A3728] text-sm leading-relaxed">Swim and splash in the river right at the property. Cool, clear water and rocky banks, the highlight of any group stay in monsoon and post-monsoon season.</p>
          </div>
        </div>

      </div>
      <p class="text-center text-[#4A3728] text-sm mt-10">Return to hot vegetarian meals made from farm-grown produce. Hot water in every room, and a bonfire to end the evening.</p>
    </div>
  </section>

  <!-- OUTSIDE EXPERIENCES -->
  <section class="py-16 px-6 lg:px-12 bg-[#F7F0E6]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <span class="font-['Caveat'] text-[#E8871A] text-2xl">Day trips from the resort</span>
        <h2 class="font-['Playfair_Display'] text-3xl font-bold text-[#2C1F0E] mt-2">Outside experiences</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

        <div class="card bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200 adv-card">
          <div class="overflow-hidden h-[220px]">
            <img src="/images/adventure-sahyadri-fort-trek-2.jpg" alt="Raigad Fort ramparts and Sahyadri hillside, Chhatrapati Shivaji's capital Maharashtra" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="p-6">
            <span class="text-xs font-semibold text-[#E8871A] uppercase tracking-wider">Heritage · 25km</span>
            <h3 class="font-['Playfair_Display'] text-xl font-bold text-[#2C1F0E] mt-1 mb-2">Raigad Fort & Ropeway</h3>
            <p class="text-[#4A3728] text-sm leading-relaxed">Walk the ramparts of Chhatrapati Shivaji's capital and ride the ropeway to the summit. 25km from Mitraay, guide and tour manager arranged.</p>
          </div>
        </div>

        <div class="card bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200 adv-card">
          <div class="overflow-hidden h-[220px]">
            <img src="/images/adventure-kolad-rafting.jpg" alt="River rafting on the Kundalika river rapids near Kolad Maharashtra" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="p-6">
            <span class="text-xs font-semibold text-[#E8871A] uppercase tracking-wider">Water · 15km</span>
            <h3 class="font-['Playfair_Display'] text-xl font-bold text-[#2C1F0E] mt-1 mb-2">Kolad River Rafting</h3>
            <p class="text-[#4A3728] text-sm leading-relaxed">Grade II–III rapids on the Kundalika river. Maharashtra's premier white water experience, 15km from Mitraay.</p>
          </div>
        </div>

        <div class="card bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200 adv-card">
          <div class="overflow-hidden h-[220px]">
            <img src="/images/adventure-mhagad-trek.jpg" alt="Mangad Trek dense Sahyadri forest trail and ridgeline near Mitraay Resort" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="p-6">
            <span class="text-xs font-semibold text-[#E8871A] uppercase tracking-wider">Trek · Nearby</span>
            <h3 class="font-['Playfair_Display'] text-xl font-bold text-[#2C1F0E] mt-1 mb-2">Mangad Trek</h3>
            <p class="text-[#4A3728] text-sm leading-relaxed">A lesser-known Sahyadri gem. Dense forest trails and dramatic ridgelines within striking distance.</p>
          </div>
        </div>

        <div class="card bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200 adv-card">
          <div class="overflow-hidden h-[220px]">
            <img src="/images/adventure-devkund-waterfall.jpg" alt="Devkund waterfall pristine jungle pool in Sahyadri forest near Mitraay Resort" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="p-6">
            <span class="text-xs font-semibold text-[#E8871A] uppercase tracking-wider">Nature · 2 hr trek</span>
            <h3 class="font-['Playfair_Display'] text-xl font-bold text-[#2C1F0E] mt-1 mb-2">Devkund Waterfall</h3>
            <p class="text-[#4A3728] text-sm leading-relaxed">A pristine jungle waterfall accessible only on foot. One of the cleanest natural pools in the Sahyadri.</p>
          </div>
        </div>

        <div class="card bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200 adv-card">
          <div class="overflow-hidden h-[220px]">
            <img src="/images/adventure-kumbhe-waterfall.jpg" alt="Kumbhe Waterfall 178-foot freefall into Raigad valley near Mitraay Resort" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
          </div>
          <div class="p-6">
            <span class="text-xs font-semibold text-[#E8871A] uppercase tracking-wider">Nature · 11km</span>
            <h3 class="font-['Playfair_Display'] text-xl font-bold text-[#2C1F0E] mt-1 mb-2">Kumbhe Waterfall</h3>
            <p class="text-[#4A3728] text-sm leading-relaxed">178 feet of freefall into lush Raigad valley. Best visited in monsoon, 11km from Mitraay.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- PHOTO GRID -->
  <section class="py-16 px-6 lg:px-12 bg-[#EDE3D4]">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-['Playfair_Display'] text-3xl font-bold text-[#2C1F0E] mb-10 text-center">Adventure in pictures</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="overflow-hidden rounded-xl md:row-span-2 adv-photo">
          <img src="/images/adventure-waterfall-aerial-view.jpg" alt="Aerial view of waterfall in the Sahyadri hills near Mitraay Resort" class="w-full h-full min-h-64 object-cover hover:scale-105 transition-transform duration-700" />
        </div>
        <div class="overflow-hidden rounded-xl adv-photo">
          <img src="/images/adventure-waterfall-sahyadri-sky.jpg" alt="Waterfall framed against Sahyadri sky near Mitraay Resort" class="w-full h-64 object-cover hover:scale-105 transition-transform duration-700" />
        </div>
        <div class="overflow-hidden rounded-xl adv-photo">
          <img src="/images/adventure-trek-rocky-ridge-group.jpg" alt="Group of trekkers on a rocky Sahyadri ridge near Mitraay Resort" class="w-full h-64 object-cover hover:scale-105 transition-transform duration-700" />
        </div>
        <div class="overflow-hidden rounded-xl md:col-span-2 adv-photo">
          <img src="/images/adventure-river-swimming-group.jpg" alt="Group swimming in the river near Mitraay Resort" class="w-full h-64 object-cover hover:scale-105 transition-transform duration-700" />
        </div>
      </div>
    </div>
  </section>

  <!-- READY TO PLAN CTA -->
  <section class="relative py-32 px-6 flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/adventure-river-swimming-group.jpg"
        alt="Group adventure at Mitraay Resort"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-[#2C1F0E]/65"></div>
    </div>
    <div class="relative z-10 text-center text-white max-w-2xl mx-auto">
      <span class="font-['Caveat'] text-[#F5B04A] text-2xl">Let's make it happen</span>
      <h2 class="font-['Playfair_Display'] text-4xl md:text-5xl font-bold mt-3 mb-6 leading-tight">
        Ready to plan your group trip?
      </h2>
      <p class="text-white/75 text-lg mb-10">
        Tell us your group size, dates, and what kind of adventure you have in mind. We'll put together a custom plan.
      </p>
      <a
        href="https://wa.me/919112984575?text=Hi%2C%20I%20want%20to%20plan%20an%20adventure%20trip%20to%20Mitraay%20Resort"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#1da851] text-white px-10 py-5 rounded-full font-semibold text-lg transition-all duration-200 shadow-2xl hover:scale-105"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Chat on WhatsApp
      </a>
    </div>
  </section>

  <!-- CUSTOM PLAN CTA -->
  <section class="py-24 px-6 bg-[#2C1F0E] text-white text-center">
    <div class="max-w-2xl mx-auto" id="adv-cta">
      <span class="font-['Caveat'] text-[#F5B04A] text-2xl">Tailored for your group</span>
      <h2 class="font-['Playfair_Display'] text-4xl font-bold mt-3 mb-6">
        Every group gets a custom activity plan.
      </h2>
      <p class="text-white/70 text-lg mb-10">
        Based on your group's fitness level, ages, and interests. We plan every day to match what your group actually wants to do.
      </p>
      <a
        href="https://wa.me/919112984575?text=Hi%2C%20I%20want%20to%20plan%20an%20adventure%20trip%20to%20Mitraay%20Resort"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#1da851] text-white px-10 py-4 rounded-full font-semibold text-lg transition-all duration-200 shadow-xl"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Plan Your Adventure
      </a>
    </div>
  </section>

</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.set(['#adv-h1', '#adv-sub'], { opacity: 0, y: 30 });
  gsap.timeline({ delay: 0.3, defaults: { ease: 'power3.out' } })
    .to('#adv-h1',  { opacity: 1, y: 0, duration: 0.9 })
    .to('#adv-sub', { opacity: 1, y: 0, duration: 0.8 }, '-=0.5');

  document.querySelectorAll('.adv-card').forEach((el, i) => {
    gsap.from(el, {
      scrollTrigger: { trigger: el, start: 'top 88%', once: true },
      y: 30, opacity: 0, duration: 0.7, delay: i * 0.1, ease: 'power2.out',
    });
  });

  document.querySelectorAll('.adv-photo').forEach((el, i) => {
    gsap.from(el, {
      scrollTrigger: { trigger: el, start: 'top 85%', once: true },
      y: 20, opacity: 0, duration: 0.7, delay: i * 0.1, ease: 'power2.out',
    });
  });

  gsap.from('#adv-cta', {
    scrollTrigger: { trigger: '#adv-cta', start: 'top 80%', once: true },
    y: 30, opacity: 0, duration: 0.9, ease: 'power3.out',
  });
</script>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('adv-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const section = canvas.parentElement as HTMLElement;
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: false, antialias: false });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const camera = new THREE.PerspectiveCamera(60, 1, 0.1, 100);
    camera.position.z = 2;
    const scene = new THREE.Scene();

    const geo = new THREE.PlaneGeometry(5, 4, 100, 80);

    const mat = new THREE.ShaderMaterial({
      uniforms: {
        uTime:  { value: 0 },
        uMouse: { value: new THREE.Vector2(0.5, 0.5) },
      },
      vertexShader: `
        uniform float uTime;
        uniform vec2  uMouse;
        varying vec2  vUv;
        void main() {
          vUv = uv;
          vec3 pos = position;
          float d = distance(uv, uMouse);
          pos.z += sin(pos.x * 6.0 + uTime * 1.4) * 0.04
                 + sin(pos.y * 5.0 + uTime * 1.2) * 0.035
                 + sin(d * 18.0 - uTime * 2.8) * 0.055 / (d + 0.3);
          gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
        }
      `,
      fragmentShader: `
        uniform float uTime;
        varying vec2  vUv;
        void main() {
          float sh = sin(vUv.x * 32.0 + uTime * 1.8) * sin(vUv.y * 22.0 + uTime * 1.5) * 0.04;
          vec3 c = vec3(0.04 + vUv.y * 0.12 + sh,
                        0.16 + vUv.y * 0.22 + sh,
                        0.32 + vUv.y * 0.28 + sh);
          gl_FragColor = vec4(c, 1.0);
        }
      `,
    });

    scene.add(new THREE.Mesh(geo, mat));

    function resize() {
      const w = section.offsetWidth, h = section.offsetHeight;
      renderer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    canvas.addEventListener('mousemove', (e: MouseEvent) => {
      const r = canvas.getBoundingClientRect();
      mat.uniforms.uMouse.value.set(
        (e.clientX - r.left) / r.width,
        1 - (e.clientY - r.top) / r.height
      );
    }, { passive: true });

    let raf = 0;
    function animate(t: number) {
      mat.uniforms.uTime.value = t / 1000;
      renderer.render(scene, camera);
      raf = requestAnimationFrame(animate);
    }
    raf = requestAnimationFrame(animate);

    window.addEventListener('beforeunload', () => cancelAnimationFrame(raf));
  }
</script>
