---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import TrustedBy from '../components/TrustedBy.astro';
---

<Layout
  title="School Trips near Raigad Fort | Mitraay"
  description="Educational farm trips near Raigad Fort. Farm tours, nature walks, river bathing, Raigad Ropeway. Day visits up to 100 students. Teachers stay free."
  ogImage="/images/school-kids-mud-river.jpg"
>

  <!-- HERO -->
  <section class="relative h-[70vh] min-h-[500px] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/school-kids-mud-river.jpg"
        alt="School kids playing in mud by the river at Mitraay Resort"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-black/10"></div>
    </div>
    <div class="relative z-10 pb-20 px-6 lg:px-12 max-w-7xl mx-auto w-full">
      <span class="font-['Caveat'] text-[#F5B04A] text-xl">Learn by doing</span>
      <h1 id="sch-h1" class="font-['Playfair_Display'] text-5xl md:text-7xl font-bold text-white mt-2 leading-tight">
        School Trips
      </h1>
      <p id="sch-sub" class="text-white/80 text-xl mt-4 max-w-xl">
        Your students will talk about this trip for years.
      </p>
    </div>
  </section>

  <!-- CAPACITY STRIP -->
  <section class="bg-[#3A5C3A] text-white py-4 px-6">
    <div class="max-w-5xl mx-auto flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm text-white/90">
      <span class="flex items-center gap-2"><span class="text-[#F5B04A]">●</span> Day visits: up to 100 students</span>
      <span class="hidden sm:inline text-white/30">|</span>
      <span class="flex items-center gap-2"><span class="text-[#F5B04A]">●</span> Overnight stays available</span>
      <span class="hidden sm:inline text-white/30">|</span>
      <span class="flex items-center gap-2"><span class="text-[#F5B04A]">●</span> Teacher accommodation: complimentary</span>
    </div>
  </section>

  <!-- WHY MITRAAY FOR SCHOOLS -->
  <section class="py-20 px-6 lg:px-12 bg-[#F7F0E6]">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div id="sch-text">
        <span class="font-['Caveat'] text-[#E8871A] text-2xl">Why Mitraay for school trips?</span>
        <h2 class="font-['Playfair_Display'] text-4xl font-bold text-[#2C1F0E] mt-3 mb-6 leading-tight">
          Classroom learning ends at the gate.<br />
          Real learning starts in the field.
        </h2>
        <p class="text-[#4A3728] text-lg leading-relaxed mb-6">
          Mitraay is designed for school groups seeking hands-on, curriculum-connected experiences. We combine agricultural learning, local history, environmental awareness, and cultural immersion, all in a safe, supervised environment.
        </p>
        <div class="flex flex-wrap gap-3">
          {['Safe & supervised', 'Teacher-accompanied', 'Structured itinerary', 'Vegetarian meals', 'Day or overnight', 'Western washrooms', 'First aid on property'].map(tag => (
            <span class="bg-[#3A5C3A]/10 text-[#3A5C3A] px-4 py-2 rounded-full text-sm font-medium">{tag}</span>
          ))}
        </div>
        <p class="text-[#4A3728] text-sm mt-5 leading-relaxed">Groups eat together in the covered indoor dining pavilion. A large TV is available for educational screenings and post-activity discussions.</p>
      </div>
      <div id="sch-img" class="overflow-hidden rounded-2xl shadow-2xl">
        <img
          src="/images/school-rice-planting-flooded-field.jpg"
          alt="School kids planting rice in a flooded paddy field at Mitraay Resort"
          class="w-full h-[450px] object-cover hover:scale-105 transition-transform duration-700"
        />
      </div>
    </div>
  </section>

  <!-- ON-PROPERTY EXPERIENCES -->
  <section class="py-16 px-6 lg:px-12 bg-[#EDE3D4]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14">
        <span class="font-['Caveat'] text-[#E8871A] text-2xl">Right here on the farm</span>
        <h2 class="font-['Playfair_Display'] text-4xl font-bold text-[#2C1F0E] mt-2">What students experience</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <div class="bg-white rounded-2xl p-6 shadow-sm sch-card">
          <div class="w-12 h-12 rounded-xl bg-[#3A5C3A]/10 flex items-center justify-center mb-5 text-[#3A5C3A]">
            <Icon name="seedling" class="w-6 h-6" />
          </div>
          <span class="text-xs font-semibold text-[#E8871A] uppercase tracking-wider">Agriculture</span>
          <h3 class="font-['Playfair_Display'] text-xl font-bold text-[#2C1F0E] mt-1 mb-3">Farm Tour</h3>
          <p class="text-[#4A3728] text-sm leading-relaxed">Walk the working farm. Students see seasonal crops up close, learn about soil, water, and food systems, from seed to plate.</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-sm sch-card">
          <div class="w-12 h-12 rounded-xl bg-[#3A5C3A]/10 flex items-center justify-center mb-5 text-[#3A5C3A]">
            <Icon name="compass" class="w-6 h-6" />
          </div>
          <span class="text-xs font-semibold text-[#E8871A] uppercase tracking-wider">Environment</span>
          <h3 class="font-['Playfair_Display'] text-xl font-bold text-[#2C1F0E] mt-1 mb-3">Nature Walk</h3>
          <p class="text-[#4A3728] text-sm leading-relaxed">Guided walk through Sahyadri foothills. Identifying plants, birds, insects, and river ecosystems in the wild.</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-sm sch-card">
          <div class="w-12 h-12 rounded-xl bg-[#8B7355]/10 flex items-center justify-center mb-5 text-[#8B7355]">
            <Icon name="waves" class="w-6 h-6" />
          </div>
          <span class="text-xs font-semibold text-[#E8871A] uppercase tracking-wider">Outdoors</span>
          <h3 class="font-['Playfair_Display'] text-xl font-bold text-[#2C1F0E] mt-1 mb-3">River Bathing</h3>
          <p class="text-[#4A3728] text-sm leading-relaxed">Safe, supervised river swim at the property bank. Students connect with a natural water body, a joyful memory they carry home.</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-sm sch-card">
          <div class="w-12 h-12 rounded-xl bg-[#D4A827]/10 flex items-center justify-center mb-5 text-[#D4A827]">
            <Icon name="pot" class="w-6 h-6" />
          </div>
          <span class="text-xs font-semibold text-[#E8871A] uppercase tracking-wider">Home Science</span>
          <h3 class="font-['Playfair_Display'] text-xl font-bold text-[#2C1F0E] mt-1 mb-3">Cooking Class</h3>
          <p class="text-[#4A3728] text-sm leading-relaxed">Traditional Konkan recipes under the open pavilion. Students learn about local ingredients, food culture, and cooking from scratch.</p>
        </div>

      </div>
      <p class="text-center text-[#4A3728] text-sm mt-10">Kids eat what they help grow: rice and vegetables from the fields.</p>
    </div>
  </section>

  <!-- OUTSIDE EXPERIENCES -->
  <section class="py-16 px-6 lg:px-12 bg-[#F7F0E6]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <span class="font-['Caveat'] text-[#E8871A] text-2xl">A short drive away</span>
        <h2 class="font-['Playfair_Display'] text-3xl font-bold text-[#2C1F0E] mt-2">Outside experiences</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">

        <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200 sch-card">
          <div class="overflow-hidden h-52">
            <img
              src="/images/school-raigad-ropeway.jpg"
              alt="Raigad Fort ropeway cable car ascending to Shivaji's capital in Sahyadri hills"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
            />
          </div>
          <div class="p-6">
            <div class="w-10 h-10 rounded-xl bg-[#E8871A]/10 flex items-center justify-center mb-4 text-[#E8871A]">
              <Icon name="mountain" class="w-5 h-5" />
            </div>
            <span class="text-xs font-semibold text-[#E8871A] uppercase tracking-wider">History · 25km</span>
            <h3 class="font-['Playfair_Display'] text-xl font-bold text-[#2C1F0E] mt-1 mb-3">Raigad Fort & Ropeway</h3>
            <p class="text-[#4A3728] text-sm leading-relaxed">Ride the ropeway up to Raigad Fort for panoramic Sahyadri views. Then walk Shivaji Maharaj's capital with a guide. A living history lesson for Class 4–12.</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200 sch-card">
          <div class="overflow-hidden h-52">
            <img
              src="/images/adventure-sahyadri-fort-trek-2.jpg"
              alt="Raigad Fort ramparts and Sahyadri hillside, Chhatrapati Shivaji's capital Maharashtra"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
            />
          </div>
          <div class="p-6">
            <div class="w-10 h-10 rounded-xl bg-[#E8871A]/10 flex items-center justify-center mb-4 text-[#E8871A]">
              <Icon name="fort" class="w-5 h-5" />
            </div>
            <span class="text-xs font-semibold text-[#E8871A] uppercase tracking-wider">Heritage · 25km</span>
            <h3 class="font-['Playfair_Display'] text-xl font-bold text-[#2C1F0E] mt-1 mb-3">Raigad Fort Trek</h3>
            <p class="text-[#4A3728] text-sm leading-relaxed">Walk the ramparts of Chhatrapati Shivaji's capital. Immersive Maratha history followed by a village walk below the fort. Guide and tour manager arranged.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="py-16 px-6 lg:px-12 bg-[#EDE3D4]">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-['Playfair_Display'] text-3xl font-bold text-[#2C1F0E] mb-10 text-center">Moments from school trips</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="col-span-2 overflow-hidden rounded-xl">
          <img src="/images/school-kids-arrival-vedbhoomi.jpg" alt="School kids arriving at Mitraay Resort, Vedbhoomi Eco Village" class="w-full h-64 object-cover hover:scale-105 transition-transform duration-700" />
        </div>
        <div class="overflow-hidden rounded-xl">
          <img src="/images/school-kids-rice-planting-faces.jpg" alt="Close-up of school kids' faces while planting rice at Mitraay Resort" class="w-full h-64 object-cover hover:scale-105 transition-transform duration-700" />
        </div>
        <div class="overflow-hidden rounded-xl">
          <img src="/images/school-kids-mud-river.jpg" alt="School kids playing in mud by the river at Mitraay Resort" class="w-full h-64 object-cover hover:scale-105 transition-transform duration-700" />
        </div>
        <div class="col-span-2 overflow-hidden rounded-xl">
          <img src="/images/school-kids-rice-planting-line.jpg" alt="Line of school kids planting rice in paddy field at Mitraay Resort" class="w-full h-64 object-cover hover:scale-105 transition-transform duration-700" />
        </div>
        <div class="col-span-2 overflow-hidden rounded-xl">
          <img src="/images/school-river-play-group.jpg" alt="School group playing and bathing in the river at Mitraay Resort" class="w-full h-64 object-cover object-top hover:scale-105 transition-transform duration-700" />
        </div>
      </div>
    </div>
  </section>

  <!-- BISHOP'S CALLOUT + TRUSTED BY -->
  <section class="py-16 px-6 lg:px-12 bg-[#2C1F0E] text-white">
    <div class="max-w-3xl mx-auto flex flex-col items-center gap-10">
      <div style="border:1px solid rgba(240,165,0,0.25); background:rgba(240,165,0,0.08); border-radius:8px; padding:1.5rem; display:flex; align-items:center; gap:1.5rem; width:100%;">
        <img src="/images/bishops.png" alt="Bishop's Co-Ed School" style="height:72px; width:auto; filter:brightness(0) invert(1); opacity:0.9; flex-shrink:0;" />
        <div>
          <p class="font-['Playfair_Display'] font-bold text-white text-xl">Bishop's Co-Ed School</p>
          <p class="text-white/70 mt-1" style="font-size:0.85rem;">Classes 5 to 10 · 2 Nights, 3 Days · Full campus exclusive stay</p>
        </div>
      </div>
      <TrustedBy showBishops={true} />
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 bg-[#2C1F0E] text-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div id="sch-cta">
        <span class="font-['Caveat'] text-[#F5B04A] text-2xl">Book a school trip</span>
        <h2 class="font-['Playfair_Display'] text-4xl font-bold mt-3 mb-6 leading-tight">
          Give your students an experience that sticks.
        </h2>
        <p class="text-white/70 text-lg mb-8">
          We work with teachers and principals to build a structured program that complements your curriculum and fits your school's budget. Day visits welcome up to 100 students; overnight stays available.
        </p>
        <a
          href="https://wa.me/919112984757?text=Hi%2C%20I%20want%20to%20enquire%20about%20a%20school%20trip%20to%20Mitraay%20Resort"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#1da851] text-white px-10 py-4 rounded-full font-semibold text-lg transition-all duration-200 shadow-xl"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Enquire About School Trips
        </a>
      </div>
      <div class="overflow-hidden rounded-2xl shadow-xl">
        <img src="/images/school-harvest-celebration-group.jpg" alt="School group celebrating harvest at Mitraay Resort farm" class="w-full h-80 object-cover" />
      </div>
    </div>
  </section>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "name": "Mitraay Agro Resort School Programs",
      "description": "Experiential farm-based school trips near Raigad Fort, Maharashtra. Farm tours, nature walks, river bathing, cooking classes, and Raigad Ropeway visits.",
      "url": "https://mitraayresort.in/school",
      "telephone": "+919112984757",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Raigad",
        "addressRegion": "Maharashtra",
        "addressCountry": "IN"
      }
    }
  </script>

</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.set(['#sch-h1', '#sch-sub'], { opacity: 0, y: 30 });
  gsap.timeline({ delay: 0.3, defaults: { ease: 'power3.out' } })
    .to('#sch-h1',  { opacity: 1, y: 0, duration: 0.9 })
    .to('#sch-sub', { opacity: 1, y: 0, duration: 0.8 }, '-=0.5');

  gsap.from('#sch-text', { scrollTrigger: { trigger: '#sch-text', start: 'top 80%', once: true }, x: -40, opacity: 0, duration: 1, ease: 'power3.out' });
  gsap.from('#sch-img',  { scrollTrigger: { trigger: '#sch-img',  start: 'top 80%', once: true }, x: 40,  opacity: 0, duration: 1, ease: 'power3.out' });

  document.querySelectorAll('.sch-card').forEach((el, i) => {
    gsap.from(el, {
      scrollTrigger: { trigger: el, start: 'top 88%', once: true },
      y: 30, opacity: 0, duration: 0.7, delay: i * 0.1, ease: 'power2.out',
    });
  });

  gsap.from('#sch-cta', {
    scrollTrigger: { trigger: '#sch-cta', start: 'top 80%', once: true },
    y: 30, opacity: 0, duration: 0.9, ease: 'power3.out',
  });
</script>
