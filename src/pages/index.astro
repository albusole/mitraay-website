<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Set initial invisible state FIRST, before any animation
  gsap.set(['#hero-brand-credit', '#hero-headline', '#hero-sub', '#hero-ctas'], { opacity: 0, y: 20 });

  // Hero entrance timeline
  const tl = gsap.timeline({ delay: 0.3, defaults: { ease: 'power3.out' } });
  tl.to('#hero-headline',      { opacity: 1, y: 0, duration: 0.9 })
    .to('#hero-brand-credit',  { opacity: 1, y: 0, duration: 0.6 }, '-=0.5')
    .to('#hero-sub',           { opacity: 1, y: 0, duration: 0.8 }, '-=0.3')
    .to('#hero-ctas',          { opacity: 1, y: 0, duration: 0.7 }, '-=0.4');

  // Hero parallax — image moves at 0.4x scroll speed
  gsap.to('#hero-parallax-img', {
    yPercent: 46,
    ease: 'none',
    scrollTrigger: {
      trigger: '#hero-section',
      start: 'top top',
      end: 'bottom top',
      scrub: true,
    },
  });

  // Scroll-triggered animations
  gsap.fromTo('#mitraay-img',
    { clipPath: 'inset(0 100% 0 0)' },
    { clipPath: 'inset(0 0% 0 0)', duration: 1.2, ease: 'power3.inOut',
      scrollTrigger: { trigger: '#mitraay-img', start: 'top 82%', once: true } }
  );
  gsap.from('#mitraay-text', {
    scrollTrigger: { trigger: '#mitraay-text', start: 'top 82%', once: true },
    x: 60, opacity: 0, duration: 1, ease: 'power3.out',
  });

  gsap.from('#pillars-heading', {
    scrollTrigger: { trigger: '#pillars-heading', start: 'top 85%', once: true },
    y: 30, opacity: 0, duration: 0.8, ease: 'power2.out',
  });

  gsap.from(['#card-1', '#card-2', '#card-3'], {
    scrollTrigger: { trigger: '#card-1', start: 'top 85%', once: true },
    y: 40, opacity: 0, duration: 0.8, ease: 'power3.out',
    stagger: 0.18,
  });

  gsap.from('#lifestyle-accent', {
    scrollTrigger: { trigger: '#lifestyle-accent', start: 'top 88%', once: true },
    y: 20, opacity: 0, duration: 0.8, ease: 'power2.out',
  });
  gsap.from('#lifestyle-strip', {
    scrollTrigger: { trigger: '#lifestyle-strip', start: 'top 90%', once: true },
    y: 20, opacity: 0, duration: 0.8, ease: 'power2.out',
  });

  gsap.fromTo('#proof-img',
    { clipPath: 'inset(0 100% 0 0)' },
    { clipPath: 'inset(0 0% 0 0)', duration: 1.2, ease: 'power3.inOut',
      scrollTrigger: { trigger: '#proof-img', start: 'top 82%', once: true } }
  );
  gsap.from('#proof-text', {
    scrollTrigger: { trigger: '#proof-text', start: 'top 82%', once: true },
    x: 50, opacity: 0, duration: 1, ease: 'power3.out',
  });

  gsap.from('#amenities-heading', {
    scrollTrigger: { trigger: '#amenities-heading', start: 'top 85%', once: true },
    y: 20, opacity: 0, duration: 0.8, ease: 'power2.out',
  });
  gsap.from('.home-amen', {
    scrollTrigger: { trigger: '#amenities-grid', start: 'top 85%', once: true },
    y: 20, opacity: 0, duration: 0.6, stagger: 0.06, ease: 'power2.out',
  });

  gsap.from('#final-cta', {
    scrollTrigger: { trigger: '#final-cta', start: 'top 82%', once: true },
    y: 40, opacity: 0, duration: 1, ease: 'power3.out',
  });

  // Stat counter: 0 → 90 on scroll into view
  const statEl = document.getElementById('stat-groups');
  if (statEl) {
    const counter = { val: 0 };
    ScrollTrigger.create({
      trigger: statEl,
      start: 'top 85%',
      once: true,
      onEnter: () => {
        gsap.to(counter, {
          val: 90,
          duration: 1.5,
          ease: 'power2.out',
          onUpdate() { statEl.textContent = Math.round(counter.val) + '+'; },
        });
      },
    });
  }


</script>
