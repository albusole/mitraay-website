---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import TrustedBy from '../components/TrustedBy.astro';
---

<Layout
  title="Mitraay Agro Resort | Farm Retreat near Raigad Fort"
  description="Group farm retreat near Raigad Fort, Raigad, Maharashtra. Exclusive stays for 22–28. Retreat groups, adventure groups, school trips. 2.5 hrs Pune, 3 hrs Mumbai."
  ogImage="/images/hero-yoga-sunrise-pavilion.jpg"
>

  <!-- HERO SECTION -->
  <section id="hero-section" class="relative h-[80vh] min-h-[560px] flex items-start overflow-hidden">
    <!-- Background image with Ken Burns -->
    <div class="absolute inset-0 ken-burns">
      <img
        id="hero-parallax-img"
        src="/images/hero-meditation-pavilion-sunset.jpg"
        alt="Meditation in the open pavilion at sunset at Mitraay Agro Resort"
        class="w-full h-[130%] object-cover object-center"
        style="margin-top: -10%"
      />
    </div>
    <!-- Dark overlay: heavier upper-left where text sits, fades to transparent -->
    <div class="absolute inset-0 bg-gradient-to-br from-black/65 via-black/25 to-transparent"></div>

    <!-- Saffron glow -->
    <div aria-hidden="true" style="position:absolute;width:520px;height:520px;top:0;left:-60px;background:radial-gradient(circle,rgba(240,165,0,0.28),transparent 65%);animation:saffron-pulse 4s ease-in-out infinite;z-index:1;pointer-events:none;"></div>

    <!-- Hero content -->
    <div class="relative z-20 pt-[18vh] px-6 lg:px-16 max-w-2xl">
      <h1 id="hero-headline" class="font-['Playfair_Display'] text-4xl md:text-5xl font-bold text-white leading-tight">
        Come with your people.<br />Leave with a story.
      </h1>
      <p id="hero-brand-credit" class="font-['Caveat'] text-[#F5B04A] text-xl mt-3">A project by Vedbhoomi Eco Village</p>
      <p id="hero-sub" class="text-white/80 text-xl mt-5 max-w-2xl leading-relaxed">
        A purposeful farm retreat near Raigad Fort, Raigad. Built for groups who want more than a getaway.
      </p>
      <div id="hero-ctas" class="flex flex-col sm:flex-row gap-4 mt-10">
        <a
          href="https://wa.me/919112984575?text=Hi%2C%20I%20want%20to%20plan%20a%20group%20trip%20to%20Mitraay%20Resort"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-[#E8871A] hover:bg-[#C96D0A] text-white px-8 py-4 rounded-full font-semibold text-lg transition-all duration-200 shadow-xl hover:shadow-2xl hover:scale-105"
        >
          Plan Your Trip →
        </a>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="bg-[#2C1F0E] text-white py-5 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-3 text-sm text-white/70">
        <span class="flex items-center gap-2"><span class="text-[#F5B04A]">●</span> 22–28 guests per trip</span>
        <span class="hidden sm:inline text-white/20">|</span>
        <span class="flex items-center gap-2"><span class="text-[#F5B04A]">●</span> Raigad Fort, 25km away</span>
        <span class="hidden sm:inline text-white/20">|</span>
        <span class="flex items-center gap-2"><span class="text-[#F5B04A]">●</span> Pune: 2.5 hrs</span>
        <span class="hidden sm:inline text-white/20">|</span>
        <span class="flex items-center gap-2"><span class="text-[#F5B04A]">●</span> Mumbai: 3 hrs</span>
        <span class="hidden sm:inline text-white/20">|</span>
        <span class="flex items-center gap-2"><span class="text-[#F5B04A]">●</span> Vegetarian · Farm-grown meals</span>
      </div>
    </div>
  </section>

  <!-- WHAT IS MITRAAY -->
  <section id="what-is-mitraay" class="py-24 px-6 lg:px-12 bg-[#F7F0E6]">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div id="mitraay-img" class="overflow-hidden rounded-2xl shadow-2xl">
        <img
          src="/images/homepage-pavilion-garden-sunset.jpg"
          alt="Open pavilion and garden at golden hour at Mitraay Agro Resort"
          class="w-full h-[500px] object-cover hover:scale-105 transition-transform duration-700"
        />
      </div>
      <div id="mitraay-text">
        <span class="font-['Caveat'] text-[#E8871A] text-2xl">What is Mitraay?</span>
        <h2 class="font-['Playfair_Display'] text-4xl md:text-5xl font-bold text-[#2C1F0E] mt-3 mb-6 leading-tight">
          A farm retreat that gives groups a story worth telling.
        </h2>
        <p class="text-[#4A3728] text-lg leading-relaxed mb-6">
          Mitraay Agro Resort is set on a working farm in Raigad, Maharashtra, surrounded by the Sahyadri hills, Ulhas river, and the ancient walls of Raigad Fort. We host groups of 22–28 for two to three-night stays focused on real experiences: farm work, fire-cooked meals, Sahyadri treks, and time away from screens.
        </p>
        <p class="text-[#4A3728] leading-relaxed mb-8">
          Whether you're a trekking or adventure group, a school group seeking hands-on learning, or a wellness retreat coming together, Mitraay gives your trip a shape and a memory.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/property" class="inline-flex items-center gap-2 text-[#E8871A] font-semibold hover:gap-3 transition-all duration-200">
            See the Property <span>→</span>
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 text-[#4A3728] font-semibold hover:text-[#E8871A] hover:gap-3 transition-all duration-200">
            Plan a Visit <span>→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- EXPERIENCE PILLARS -->
  <section class="py-24 px-6 lg:px-12 bg-[#EDE3D4]">
    <div class="max-w-7xl mx-auto">
      <div id="pillars-heading" class="text-center mb-16">
        <span class="font-['Caveat'] text-[#E8871A] text-2xl">Three ways to experience Mitraay</span>
        <h2 class="font-['Playfair_Display'] text-4xl md:text-5xl font-bold text-[#2C1F0E] mt-3">
          What brings you here?
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Retreat card -->
        <div id="card-1" class="card group relative overflow-hidden rounded-2xl shadow-xl cursor-pointer">
          <div class="overflow-hidden h-80">
            <img
              src="/images/retreat-meditation-sunrise-wide.jpg"
              alt="Wide-angle meditation at sunrise in Mitraay Resort pavilion"
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
            />
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
            <span class="font-['Caveat'] text-[#F5B04A] text-lg">Recharge</span>
            <h3 class="font-['Playfair_Display'] text-2xl font-bold mb-3">Retreat</h3>
            <p class="text-white/80 text-sm mb-4">Yoga, spiritual, and wellness retreats. Guided sessions, farm-grown meals, complete privacy.</p>
            <a href="/retreat" class="inline-flex items-center gap-2 text-[#F5B04A] font-semibold text-sm hover:gap-3 transition-all duration-200">
              Plan a retreat →
            </a>
          </div>
        </div>

        <!-- Adventure card -->
        <div id="card-2" class="card group relative overflow-hidden rounded-2xl shadow-xl cursor-pointer">
          <div class="overflow-hidden h-80">
            <img
              src="/images/adventure-river-swimming-group.jpg"
              alt="Group swimming in the river near Mitraay Resort"
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
            />
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
            <span class="font-['Caveat'] text-[#F5B04A] text-lg">Explore outdoors</span>
            <h3 class="font-['Playfair_Display'] text-2xl font-bold mb-3">Adventure</h3>
            <p class="text-white/80 text-sm mb-4">River treks, waterfall visits, Raigad Fort, bonfire nights, farm activities: custom planned for your group.</p>
            <a href="/adventure" class="inline-flex items-center gap-2 text-[#F5B04A] font-semibold text-sm hover:gap-3 transition-all duration-200">
              Explore adventures →
            </a>
          </div>
        </div>

        <!-- School card -->
        <div id="card-3" class="card group relative overflow-hidden rounded-2xl shadow-xl cursor-pointer">
          <div class="overflow-hidden h-80">
            <img
              src="/images/school-kids-activity-circle.jpg"
              alt="School kids in a learning activity circle at Mitraay Resort"
              class="w-full h-full object-cover object-[center_40%] group-hover:scale-110 transition-transform duration-700"
            />
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
            <span class="font-['Caveat'] text-[#F5B04A] text-lg">Learn by doing</span>
            <h3 class="font-['Playfair_Display'] text-2xl font-bold mb-3">School Trips</h3>
            <p class="text-white/80 text-sm mb-4">Paddy planting, cooking classes, Raigad Fort history, nature trails. Safe, structured, unforgettable.</p>
            <a href="/school" class="inline-flex items-center gap-2 text-[#F5B04A] font-semibold text-sm hover:gap-3 transition-all duration-200">
              Plan a school trip →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AMENITIES -->
  <section class="py-12 px-6 lg:px-12 bg-[#3A5C3A]">
    <div class="max-w-4xl mx-auto">
      <h2 id="amenities-heading" class="font-['Playfair_Display'] text-3xl font-bold text-white text-center mb-8">Everything your group needs</h2>
      <div id="amenities-grid" class="flex flex-wrap justify-center gap-3">
        <span class="home-amen flex items-center gap-2 bg-white/10 border border-white/10 px-4 py-2.5 rounded-full text-sm text-white/85 font-medium"><Icon name="wifi" class="w-4 h-4 text-[#F5B04A] flex-shrink-0" />WiFi across the property</span>
        <span class="home-amen flex items-center gap-2 bg-white/10 border border-white/10 px-4 py-2.5 rounded-full text-sm text-white/85 font-medium"><Icon name="car" class="w-4 h-4 text-[#F5B04A] flex-shrink-0" />Free parking</span>
        <span class="home-amen flex items-center gap-2 bg-white/10 border border-white/10 px-4 py-2.5 rounded-full text-sm text-white/85 font-medium"><Icon name="drop" class="w-4 h-4 text-[#F5B04A] flex-shrink-0" />Hot water in all rooms</span>
        <span class="home-amen flex items-center gap-2 bg-white/10 border border-white/10 px-4 py-2.5 rounded-full text-sm text-white/85 font-medium"><Icon name="house" class="w-4 h-4 text-[#F5B04A] flex-shrink-0" />Western washrooms</span>
        <span class="home-amen flex items-center gap-2 bg-white/10 border border-white/10 px-4 py-2.5 rounded-full text-sm text-white/85 font-medium"><Icon name="utensils" class="w-4 h-4 text-[#F5B04A] flex-shrink-0" />Indoor dining pavilion</span>
        <span class="home-amen flex items-center gap-2 bg-white/10 border border-white/10 px-4 py-2.5 rounded-full text-sm text-white/85 font-medium"><Icon name="sun" class="w-4 h-4 text-[#F5B04A] flex-shrink-0" />Yoga and event pavilion</span>
        <span class="home-amen flex items-center gap-2 bg-white/10 border border-white/10 px-4 py-2.5 rounded-full text-sm text-white/85 font-medium"><Icon name="music" class="w-4 h-4 text-[#F5B04A] flex-shrink-0" />Sound system</span>
        <span class="home-amen flex items-center gap-2 bg-white/10 border border-white/10 px-4 py-2.5 rounded-full text-sm text-white/85 font-medium"><Icon name="mic" class="w-4 h-4 text-[#F5B04A] flex-shrink-0" />Karaoke on request</span>
        <span class="home-amen flex items-center gap-2 bg-white/10 border border-white/10 px-4 py-2.5 rounded-full text-sm text-white/85 font-medium"><Icon name="monitor" class="w-4 h-4 text-[#F5B04A] flex-shrink-0" />Large TV for presentations</span>
        <span class="home-amen flex items-center gap-2 bg-white/10 border border-white/10 px-4 py-2.5 rounded-full text-sm text-white/85 font-medium"><Icon name="flame" class="w-4 h-4 text-[#F5B04A] flex-shrink-0" />Bonfire area</span>
        <span class="home-amen flex items-center gap-2 bg-white/10 border border-white/10 px-4 py-2.5 rounded-full text-sm text-white/85 font-medium"><Icon name="medkit" class="w-4 h-4 text-[#F5B04A] flex-shrink-0" />First aid on property</span>
        <span class="home-amen flex items-center gap-2 bg-white/10 border border-white/10 px-4 py-2.5 rounded-full text-sm text-white/85 font-medium"><Icon name="leaf" class="w-4 h-4 text-[#F5B04A] flex-shrink-0" />Vegetarian farm-grown meals</span>
      </div>
    </div>
  </section>

  <!-- LIFESTYLE STRIP -->
  <section class="py-20 px-6 lg:px-12 bg-[#F7F0E6]">
    <div class="max-w-7xl mx-auto">
      <div id="lifestyle-accent" class="text-center mb-12">
        <span class="font-['Caveat'] text-[#E8871A] text-4xl md:text-5xl">Wake up to this.</span>
      </div>
      <div id="lifestyle-strip" class="flex gap-4 md:gap-6 overflow-x-auto pb-2 md:pb-0 md:overflow-x-visible">
        <div class="flex-shrink-0 w-[70vw] md:w-[38%] overflow-hidden rounded-xl shadow-lg">
          <img
            src="/images/homepage-chai-treehouse-sunrise.jpg"
            alt="Morning chai with treehouse and sunrise view at Mitraay Resort"
            class="w-full h-72 md:h-96 object-cover hover:scale-105 transition-transform duration-700"
          />
        </div>
        <div class="flex-shrink-0 w-[70vw] md:w-[34%] overflow-hidden rounded-xl shadow-lg">
          <img
            src="/images/homepage-pavilion-garden-sunset.jpg"
            alt="Open pavilion and garden at sunset at Mitraay Resort"
            class="w-full h-72 md:h-96 object-cover hover:scale-105 transition-transform duration-700"
          />
        </div>
        <div class="flex-shrink-0 w-[70vw] md:w-[24%] overflow-hidden rounded-xl shadow-lg">
          <img
            src="/images/property-swing-sunrise-grounds.jpg"
            alt="Swing at sunrise on the resort grounds at Mitraay Resort"
            class="w-full h-72 md:h-96 object-cover hover:scale-105 transition-transform duration-700"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="py-24 px-6 lg:px-12 bg-[#EDE3D4]">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div id="proof-img" class="overflow-hidden rounded-2xl shadow-2xl order-2 lg:order-1">
        <img
          src="/images/stories-group-night-flag.jpg"
          alt="Group gathering at night with flag at Mitraay Resort"
          class="w-full h-[450px] object-cover hover:scale-105 transition-transform duration-700"
        />
      </div>
      <div id="proof-text" class="order-1 lg:order-2">
        <span class="font-['Caveat'] text-[#E8871A] text-2xl">What groups say</span>
        <blockquote class="font-['Playfair_Display'] text-3xl md:text-4xl font-bold text-[#2C1F0E] mt-4 mb-8 leading-tight">
          "We didn't just visit.<br />We lived it for two days."
        </blockquote>
        <div class="grid grid-cols-2 gap-6 mb-8">
          <div class="bg-white rounded-xl p-5 shadow-sm">
            <p id="stat-groups" class="font-['Playfair_Display'] text-4xl font-bold text-[#E8871A]">90+</p>
            <p class="text-[#4A3728] text-sm mt-1">Groups hosted</p>
          </div>
          <div class="bg-white rounded-xl p-5 shadow-sm">
            <p class="font-['Playfair_Display'] text-4xl font-bold text-[#E8871A]">22–28</p>
            <p class="text-[#4A3728] text-sm mt-1">Guests per stay</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-3">
          <span class="bg-[#3A5C3A]/10 text-[#3A5C3A] px-4 py-2 rounded-full text-sm font-medium">School trips</span>
          <span class="bg-[#3A5C3A]/10 text-[#3A5C3A] px-4 py-2 rounded-full text-sm font-medium">Adventure groups</span>
          <span class="bg-[#3A5C3A]/10 text-[#3A5C3A] px-4 py-2 rounded-full text-sm font-medium">Spiritual retreats</span>
          <span class="bg-[#3A5C3A]/10 text-[#3A5C3A] px-4 py-2 rounded-full text-sm font-medium">Wellness groups</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUSTED BY -->
  <section class="py-16 px-6 bg-[#2C1F0E]">
    <TrustedBy />
  </section>

  <!-- FINAL CTA -->
  <section class="relative py-32 px-6 flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/homepage-pavilion-garden-sunset.jpg"
        alt="Open pavilion and garden at sunset at Mitraay Resort"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-[#2C1F0E]/65"></div>
    </div>
    <div id="final-cta" class="relative z-10 text-center text-white max-w-2xl mx-auto">
      <span class="font-['Caveat'] text-[#F5B04A] text-2xl">Let's make it happen</span>
      <h2 class="font-['Playfair_Display'] text-4xl md:text-5xl font-bold mt-3 mb-6 leading-tight">
        Ready to plan your group trip?
      </h2>
      <p class="text-white/75 text-lg mb-10">
        Tell us your group size, dates, and what you have in mind. We'll put together a personalised itinerary.
      </p>
      <a
        href="https://wa.me/919112984575?text=Hi%2C%20I%20want%20to%20plan%20a%20group%20trip%20to%20Mitraay%20Resort"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#1da851] text-white px-10 py-5 rounded-full font-semibold text-lg transition-all duration-200 shadow-2xl hover:scale-105"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Chat on WhatsApp
      </a>
    </div>
  </section>

  <!-- UPCOMING EVENTS -->
  <section class="py-20 px-6 lg:px-12 bg-[#3A5C3A]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <span class="font-['Caveat'] text-[#F5B04A] text-2xl">What's coming up</span>
        <h2 class="font-['Playfair_Display'] text-4xl md:text-5xl font-bold text-white mt-3">Upcoming Events</h2>
      </div>
      <div class="flex justify-center">
        <div class="card bg-[#2A4A2A] border border-[#F5B04A]/25 rounded-2xl shadow-xl max-w-lg w-full">
          <div class="p-8">
            <span class="inline-block bg-[#F5B04A]/15 text-[#F5B04A] text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-5 font-['DM_Sans']">10 – 24 August 2026</span>
            <h3 class="font-['Playfair_Display'] text-2xl font-bold text-white mb-2 leading-snug">Detox &amp; Naturopathy Camp</h3>
            <p class="font-['DM_Sans'] text-[#F5B04A]/80 text-sm font-medium mb-4">Dr. Jeeva &amp; Dr. Rukhmani</p>
            <p class="font-['DM_Sans'] text-white/65 text-sm leading-relaxed mb-5">A 14-day naturopathy and detox program at Mitraay. Mud therapy, therapeutic fasting, nature cure, and daily guided sessions in the open pavilion. Farm-grown sattvic meals throughout.</p>
            <div class="flex items-center gap-2 mb-7">
              <span class="w-2 h-2 rounded-full bg-[#F5B04A] flex-shrink-0"></span>
              <p class="font-['DM_Sans'] text-white/55 text-sm">Limited to 18 participants</p>
            </div>
            <a
              href="https://wa.me/919112984757?text=Hi%2C%20I%20want%20to%20enquire%20about%20the%20Detox%20and%20Naturopathy%20Camp%20at%20Mitraay%20in%20August%202026"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#1da851] text-white px-6 py-3 rounded-full font-semibold text-sm transition-all duration-200 shadow-lg hover:scale-105 font-['DM_Sans']"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 flex-shrink-0">
